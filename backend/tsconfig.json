{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ESNext"],
    "types": ["node"],
    
    /* Output settings */
    "outDir": "./dist",
    "rootDir": "./src",
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    /* Interop Constraints */
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    
    /* Strictness */
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,

    /* Changed verbatimModuleSyntax to false or removed. 
       If true, it forces you to use 'import type' for everything 
       that isn't a value, which can be annoying starting out.
    */
    "verbatimModuleSyntax": false 
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}